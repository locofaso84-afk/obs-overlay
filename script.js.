// =========================// CHAT DEMO// =========================
const mensajes=[
["Juan","Qué buen programa "],
["María","Saludos desde Córdoba"],
["Pedro","Excelente entrevista"],
["Lucas","Aguante Vimos Luz y Entramos"],
["Ana","Los miro todas las semanas"],
["Sofi","Muy buena la producción"]
];
function agregarMensaje(){
const lista=document.getElementById("mensajes");
const random=mensajes[Math.floor(Math.random()*mensajes.length)];
const div=document.createElement("div");
div.style.marginBottom="14px";
div.innerHTML="<span style='color:#FFC400;font-weight:700;'>"+random[0]+"</span><br>"+random[1];
lista.prepend(div);
while(lista.children.length>10){
lista.removeChild(lista.lastChild);
}
}
for(let i=0;i<5;i++){
agregarMensaje();
}
setInterval(agregarMensaje,6000);


